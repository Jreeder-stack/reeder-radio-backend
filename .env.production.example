# =============================================================================
# Command Comms — Production Environment Variables
# Copy this file to .env and fill in all required values.
# =============================================================================

# --- Core (required) ---------------------------------------------------------

# Node environment — must be "production" for secure cookies and optimizations
NODE_ENV=production

# Port the Node.js server listens on (nginx proxies to this)
PORT=3001

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@localhost:5432/DATABASE
DATABASE_URL=postgresql://command_comms:CHANGE_ME@localhost:5432/command_comms

# Express session secret — use a long random string (e.g. openssl rand -hex 32)
SESSION_SECRET=CHANGE_ME

# --- Admin account (required on first run) ------------------------------------

# Default admin credentials created on first database initialization
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME

# --- LiveKit (required for voice/PTT) ----------------------------------------

# LiveKit Cloud or self-hosted credentials
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-livekit-instance.livekit.cloud

# --- Azure Speech Services (required for AI dispatcher) -----------------------

# Azure Cognitive Services Speech key and region
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# --- Azure OpenAI (required for AI dispatcher intent parsing) -----------------

# Azure OpenAI service credentials
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# --- Audio Relay (optional) ---------------------------------------------------

# UDP port for the custom audio relay service
AUDIO_RELAY_PORT=5100

# Hostname clients use to reach the audio relay (defaults to request hostname)
AUDIO_RELAY_HOST=

# Transport mode: "custom-radio" or "livekit"
RADIO_TRANSPORT_MODE=custom-radio

# Whether to use TLS for signaling (defaults to true in production)
RADIO_USE_TLS=true

# Override signaling WebSocket URL (auto-detected if not set)
RADIO_SIGNALING_URL=

# --- AI Dispatcher (optional) ------------------------------------------------

# Azure TTS voice for AI dispatcher responses
AI_DISPATCHER_VOICE=en-US-GuyNeural

# --- CAD Integration (optional) -----------------------------------------------

# External CAD system URL and API key
CAD_URL=
CAD_API_KEY=
