modules = ["nodejs-20", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["unzip"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Frontend"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm start"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Frontend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd client && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 5173
externalPort = 5173

[userenv]

[userenv.development]
VITE_LIVEKIT_URL = "wss://reeder-ptt-rcm02mdx.livekit.cloud"
CAD_URL = "https://d6a6688f-3b7a-4b61-89a7-60fd65e2cbb5-00-1pafxgsywyu8q.spock.replit.dev"

[userenv.shared]
AZURE_SPEECH_REGION = "eastus"

[userenv.production]
CAD_URL = "https://cad.reeder-systems.com"

[deployment]
deploymentTarget = "autoscale"
run = ["node", "server.js"]
build = ["bash", "-c", "cd client && npm run build"]
