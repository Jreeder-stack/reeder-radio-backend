<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <uses-permission android:name="android.permission.BROADCAST_STICKY" />

    <application
        android:name=".CommandCommsApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.CommandComms"
        android:usesCleartextTraffic="false">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".audio.BackgroundAudioService"
            android:exported="false"
            android:foregroundServiceType="microphone|location" />

        <!--
            Exported so Inrico T320 firmware broadcasts reach this receiver regardless of
            screen state or app lifecycle. No accessibility service required for screen-off PTT.
        -->
        <receiver
            android:name=".audio.PttHardwareReceiver"
            android:exported="true">
            <!-- Internal self-sent actions (foreground / legacy callers) -->
            <intent-filter>
                <action android:name="com.reedersystems.commandcomms.PTT_DOWN" />
                <action android:name="com.reedersystems.commandcomms.PTT_UP" />
            </intent-filter>
            <!-- Generic Android PTT broadcast (pttKeyState extra) -->
            <intent-filter>
                <action android:name="android.intent.action.PTT" />
            </intent-filter>
            <!-- Inrico T320 firmware — confirmed primary actions from Zello logcat (dot-separated, lowercase) -->
            <intent-filter>
                <action android:name="android.intent.action.PTT.down" />
                <action android:name="android.intent.action.PTT.up" />
            </intent-filter>
            <!-- Inrico T320 firmware — longpress (consumed to suppress built-in beep sounds) -->
            <intent-filter android:priority="999">
                <action android:name="android.intent.action.PTT.longpress" />
                <action android:name="android.intent.action.PTT_LONGPRESS" />
                <action android:name="com.inrico.ptt.longpress" />
                <action android:name="com.inrico.intent.action.PTT_LONGPRESS" />
            </intent-filter>
            <!-- Inrico T320 firmware — underscore variant -->
            <intent-filter>
                <action android:name="android.intent.action.PTT_DOWN" />
                <action android:name="android.intent.action.PTT_UP" />
            </intent-filter>
            <!-- Inrico T320 firmware — standard Android namespace (_KEY_ variant) -->
            <intent-filter>
                <action android:name="android.intent.action.PTT_KEY_DOWN" />
                <action android:name="android.intent.action.PTT_KEY_UP" />
            </intent-filter>
            <!-- Inrico T320 firmware — vendor namespace (lowercase, confirmed) -->
            <intent-filter>
                <action android:name="com.inrico.ptt.down" />
                <action android:name="com.inrico.ptt.up" />
            </intent-filter>
            <!-- Inrico T320 firmware — vendor namespace (PTT_KEY_ prefix variant) -->
            <intent-filter>
                <action android:name="com.inrico.ptt.PTT_KEY_DOWN" />
                <action android:name="com.inrico.ptt.PTT_KEY_UP" />
            </intent-filter>
            <!-- Inrico T320 firmware — vendor namespace with intent.action prefix -->
            <intent-filter>
                <action android:name="com.inrico.intent.action.PTT_DOWN" />
                <action android:name="com.inrico.intent.action.PTT_UP" />
            </intent-filter>
            <!-- Inrico T320 firmware — telecom namespace (some ROM versions) -->
            <intent-filter>
                <action android:name="com.android.server.telecom.PushToTalk.action.PTT_KEY_DOWN" />
                <action android:name="com.android.server.telecom.PushToTalk.action.PTT_KEY_UP" />
            </intent-filter>
            <!-- Internal emergency actions -->
            <intent-filter>
                <action android:name="com.reedersystems.commandcomms.EMERGENCY_DOWN" />
                <action android:name="com.reedersystems.commandcomms.EMERGENCY_UP" />
            </intent-filter>
            <!-- Android generic emergency broadcasts -->
            <intent-filter>
                <action android:name="android.intent.action.EMERGENCY_DOWN" />
                <action android:name="android.intent.action.EMERGENCY_UP" />
            </intent-filter>
            <!-- Inrico T320 emergency — dot-separated lowercase (mirrors PTT.down / PTT.up) -->
            <intent-filter>
                <action android:name="android.intent.action.EMERGENCY.down" />
                <action android:name="android.intent.action.EMERGENCY.up" />
            </intent-filter>
            <!-- Inrico T320 vendor emergency broadcasts -->
            <intent-filter>
                <action android:name="com.inrico.emergency.down" />
                <action android:name="com.inrico.emergency.up" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.inrico.emergency.EMERGENCY.down" />
                <action android:name="com.inrico.emergency.EMERGENCY.up" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.inrico.intent.action.EMERGENCY_DOWN" />
                <action android:name="com.inrico.intent.action.EMERGENCY_UP" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.inrico.intent.action.EMERGENCY.down" />
                <action android:name="com.inrico.intent.action.EMERGENCY.up" />
            </intent-filter>
            <!-- SOS variants — some Inrico firmware labels the emergency button as SOS -->
            <intent-filter>
                <action android:name="android.intent.action.SOS_KEY_DOWN" />
                <action android:name="android.intent.action.SOS_KEY_UP" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.inrico.sos.down" />
                <action android:name="com.inrico.sos.up" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.inrico.intent.action.SOS_KEY_DOWN" />
                <action android:name="com.inrico.intent.action.SOS_KEY_UP" />
            </intent-filter>
            <!-- Confirmed SOS broadcasts from PhoneWindowManager on Inrico T320 (screen-off emergency button) -->
            <intent-filter>
                <action android:name="android.intent.action.SOS.down" />
                <action android:name="android.intent.action.SOS.up" />
                <action android:name="android.intent.action.SOS.shortpress" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".field.BootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
