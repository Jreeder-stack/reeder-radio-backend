<?xml version="1.0" encoding="utf-8"?>
<!--
    FOREGROUND-ONLY FALLBACK — OPTIONAL.

    This accessibility service intercepts PTT hardware key events while the app is
    in the foreground. It is NOT required for background or screen-off PTT on the
    Inrico T320. The primary screen-off PTT path uses PttHardwareReceiver (an exported
    BroadcastReceiver that catches vendor firmware broadcasts directly, with no dependency
    on this service and no susceptibility to battery-saver revocation).

    Enable this service only if vendor broadcasts are not available on your device
    (non-Inrico hardware) or as an additional foreground key-event layer.
-->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeAllMask"
    android:accessibilityFlags="flagRequestFilterKeyEvents"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:canRequestFilterKeyEvents="true"
    android:description="@string/accessibility_service_description"
    android:notificationTimeout="100" />
